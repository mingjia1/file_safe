DATABASE_TYPE=sqlite
DATABASE_URL=sqlite+aiosqlite:///./ptm.db
DATABASE_URL_SYNC=sqlite:///./ptm.db

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DATABASE=ptm

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

DEBUG=true
